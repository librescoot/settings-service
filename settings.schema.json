{
  "alarm.enabled": {
    "type": "bool",
    "description": "Enable or disable the alarm system",
    "label": "Alarm",
    "user-visible": true,
    "service": "alarm-service",
    "default": true,
    "example": true
  },
  "alarm.honk": {
    "type": "bool",
    "description": "Enable horn during alarm trigger",
    "label": "Alarm Horn",

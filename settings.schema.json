    "default": false,
    "example": false
  },
  "scooter.dual-battery": {
    "type": "bool",
    "description": "Enable dual battery mode (battery 1 active instead of idle)",
    "label": "Dual Battery Mode",
    "user-visible": true,
    "service": "battery-service",
    "default": false,
    "example": true
  },
  "scooter.max-voltage-delta": {
    "type": "int",

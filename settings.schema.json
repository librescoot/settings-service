    "service": "alarm-service",
    "default": false,
    "example": true
  },
  "alarm.hairtrigger-duration": {
    "type": "int",
    "description": "Duration in seconds for hair trigger alarm",
    "label": "Hair Trigger Duration",
    "user-visible": false,
    "service": "alarm-service",
    "default": 3,
    "unit": "seconds",
    "min": 1,
    "max": 30,
    "example": 3
  },
  "alarm.l1-cooldown": {
    "type": "int",
    "description": "Level 1 cooldown duration in seconds",

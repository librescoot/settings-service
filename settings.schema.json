    "unit": "seconds",
    "min": 0,
    "max": 300,
    "example": 60
  },
  "alarm.seatbox-trigger": {
    "type": "bool",
    "description": "Trigger alarm on unauthorized seatbox opening",
    "label": "Seatbox Alarm Trigger",
    "user-visible": false,
